{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gradle-build",
            "type": "shell",
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "$env:JAVA_HOME = 'C:\\\\Users\\\\princ\\\\Andriod Attendance App\\\\jdk-17.0.2'; & '${workspaceFolder}\\\\gradlew.bat' assembleDebug"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
