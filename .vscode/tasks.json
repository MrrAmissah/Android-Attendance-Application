                    "-Command",
                    "$env:JAVA_HOME = 'C:\\\\Users\\\\princ\\\\Andriod Attendance App\\\\jdk-17.0.2'; & '${workspaceFolder}\\\\gradlew.bat' clean assembleDebug"
